# IntelliStore – environment variables example
# Copy this file to .env and fill in your values before running docker-compose.
# NEVER commit the .env file to source control.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=intellistore
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=intellistore

# Full DSN (used by both API and ETL containers)
DATABASE_URL=postgresql://intellistore:change_me_in_production@postgres:5432/intellistore

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
# Create a project at https://console.cloud.google.com/apis/credentials
# and add your OAuth 2.0 Client ID here.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ---------------------------------------------------------------------------
# Application JWT
# ---------------------------------------------------------------------------
# Generate a strong random secret, e.g.:  openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Forecast model
# ---------------------------------------------------------------------------
# Path to the trained .pkl model inside the api container.
# Default: /app/models/forecast/model.pkl  (set by Dockerfile)
# FORECAST_MODEL_PATH=/app/models/forecast/model.pkl

# ---------------------------------------------------------------------------
# Upload settings
# ---------------------------------------------------------------------------
UPLOADS_DIR=/data/uploads
MAX_UPLOAD_SIZE_BYTES=52428800   # 50 MB

# ETL service URL (used by the API to trigger ETL runs)
ETL_SERVICE_URL=http://etl:8001
ETL_TRIGGER_TIMEOUT_SECONDS=10
